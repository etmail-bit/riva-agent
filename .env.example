# 複製這份檔案為 .env，填入真實值。.env 不會進版控。
FIRECRAWL_API_KEY=

# Turso 雲端資料庫（月盈虧上雲用）：turso db show <db名> --url / turso db tokens create <db名>
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# 真實店名 <-> 代稱對照表
STORE_A_REAL_NAME=your_store_name_here
STORE_B_REAL_NAME=your_store_name_here

# 真實員工姓名 <-> 代碼對照表（取姓名中最有辨識度的一個字當代碼）
# EMPLOYEE_<代碼>_NAME=真實姓名
EMPLOYEE_X_NAME=your_employee_name_here
